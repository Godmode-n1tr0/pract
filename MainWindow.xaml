<Window x:Class="pract7.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:pract7"
        mc:Ignorable="d"
        Title="DataBinding" Height="485" Width="630">
    <DockPanel  LastChildFill="False">
        <StackPanel DockPanel.Dock="Bottom">
            <StatusBar Height="25" Width="auto" Margin="10 5 10 5" Background="LightGray" Padding="5 0 0 0">Готово</StatusBar>
        </StackPanel>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="1.9*"/>
                <RowDefinition Height="0.7*"/>
                <RowDefinition Height="0.9*"/>
            </Grid.RowDefinitions>
            <StackPanel Grid.Row="0" Grid.Column="0">
                <StackPanel Orientation="Horizontal">
                    <Label Width="80">Фамилия:</Label>
                    <TextBox x:Name="f" Width="100" Height="20" Margin="5 2 0 0"></TextBox>
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <Label Width="80">Имя:</Label>
                    <TextBox x:Name="i" Width="100" Height="20" Margin="5 2 0 0"></TextBox>
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <Label Width="80">Отчество:</Label>
                    <TextBox x:Name="o" Width="100" Height="20" Margin="5 2 0 0"></TextBox>
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <Label Width="95">Специализация</Label>
                    <ComboBox x:Name="spec" Width="85" Height="20" Margin="5 3 0 0">
                        <ComboBoxItem Name="Хирург">Хирург</ComboBoxItem>
                        <ComboBoxItem Name="Терапевт">Терапевт</ComboBoxItem>
                        <ComboBoxItem Name="Стоматолог">Стоматолог</ComboBoxItem>
                        <ComboBoxItem Name="Педиатр">Педиатр</ComboBoxItem>
                        <ComboBoxItem Name="Дерматолог">Дерматолог</ComboBoxItem>
                    </ComboBox>
                </StackPanel>
                <StackPanel Orientation="Vertical">
                    <Label>Пароль:</Label>
                    <TextBox x:Name="par" Width="auto" Height="20" Margin="10 0 10 0"></TextBox>
                </StackPanel>
                <StackPanel Orientation="Vertical">
                    <Label>Подтвердение пароля:</Label>
                    <TextBox x:Name="ppar" Width="auto" Height="20" Margin="10 0 10 0"></TextBox>
                </StackPanel>
                <Button Height="20" Margin="40 5 40 0" Click="Button_Click">Регистрация</Button>
            </StackPanel>
            <StackPanel Grid.Row="1" Grid.Column="0" Margin="0 5 0 0">
                <StackPanel Orientation="Horizontal">
                    <Label Width="80">ID врача</Label>
                    <TextBox x:Name="id_vrach" Width="100" Height="20" Margin="5 0 5 0"></TextBox>
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <Label Width="80">Пароль</Label>
                    <TextBox x:Name="Pas_vhod" Width="100" Height="20" Margin="5 0 5 0"></TextBox>
                </StackPanel>
                <Button Height="20" Margin="40 5 40 0" Click="Button_Click_1">Вход</Button>
            </StackPanel>
            <StackPanel Grid.Row="2" Grid.Column="0">
                <Label>Фио:</Label>
                <Label Height="25" FontSize="10"></Label>
                <Label Margin="0 5 0 0">Специализация:</Label>
                <Label Height="25" FontSize="10"></Label>
            </StackPanel>
        </Grid>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.5*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="0.1*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <StackPanel Grid.Row="0" Grid.Column="1">
                <StackPanel Orientation="Horizontal">
                    <Label Width="80">Поиск по ID:</Label>
                    <TextBox Width="150" Margin="0 4 5 2"></TextBox>
                </StackPanel>
            </StackPanel>
            <StackPanel Grid.Row="2" Grid.Column="0">
                <Label>Фио:</Label>
                <Label Height="25" FontSize="10" Margin="5 0 5 0"></Label>
                <Label Margin="0 5 0 0">Дата рождения:</Label>
                <Label Height="25" FontSize="10" Margin="5 0 5 0"></Label>
                <StackPanel Orientation="Horizontal">
                    <Label Width="115">Последний прием:</Label>
                    <DatePicker Width="115" Margin="0 2 5 2"></DatePicker>
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <Label Width="80">Диагноз:</Label>
                    <TextBox Width="150" Margin="0 4 5 2"></TextBox>
                </StackPanel>
                <StackPanel Orientation="Vertical">
                    <Label>Рекомендации:</Label>
                    <TextBox Width="auto" Margin="5 0 5 2" Padding="0 0 0 30"></TextBox>
                </StackPanel>
            </StackPanel>
        </Grid>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="1*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <StackPanel Grid.Row="0" Grid.Column="0">
                <StackPanel Orientation="Horizontal">
                    <Label Width="80">Фамилия:</Label>
                    <TextBox x:Name="f_pac" Width="100" Height="20" Margin="5 2 5 0"></TextBox>
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <Label Width="80">Имя:</Label>
                    <TextBox x:Name="i_pac" Width="100" Height="20" Margin="5 2 5 0"></TextBox>
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <Label Width="80">Отчество:</Label>
                    <TextBox x:Name="o_pac" Width="100" Height="20" Margin="5 2 5 0"></TextBox>
                </StackPanel>
                <StackPanel Orientation="Vertical">
                    <Label>Дата рождения:</Label>
                    <DatePicker x:Name="date_pac" Width="100" Margin="5 2 0 3"></DatePicker>
                </StackPanel>
                <Button Height="20" Margin="20 5 20 0" Click="Button_Click_2">Регистрация пациента</Button>
            </StackPanel>
            <StackPanel Grid.Row="1" Grid.Column="0">
                <StackPanel Orientation="Horizontal">
                    <Label Width="80">Фамилия:</Label>
                    <TextBox Width="100" Height="20" Margin="5 2 5 0"></TextBox>
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <Label Width="80">Имя:</Label>
                    <TextBox Width="100" Height="20" Margin="5 2 5 0"></TextBox>
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <Label Width="80">Отчество:</Label>
                    <TextBox Width="100" Height="20" Margin="5 2 5 0"></TextBox>
                </StackPanel>
                <StackPanel Orientation="Vertical">
                    <Label>Дата рождения:</Label>
                    <DatePicker Width="100" Margin="5 2 0 3"></DatePicker>
                </StackPanel>
                <Button Height="20" Margin="20 5 20 0">Изменение пациента</Button>
            </StackPanel>
        </Grid>
    </DockPanel>
</Window>
