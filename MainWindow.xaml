<Window x:Class="pract7.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:pract7"
        mc:Ignorable="d"
        Title="DataBinding" Height="485" Width="630">

    <DockPanel LastChildFill="False">
        <StackPanel DockPanel.Dock="Bottom">
            <StatusBar Height="30" Width="auto" Margin="10 5 10 5" Background="LightGray" Padding="5 0 0 0">
                <StackPanel Orientation="Horizontal">
                    <StackPanel Orientation="Horizontal">
                        <Label FontSize="10">Кол-во врачей:</Label>
                        <Label Padding="10 3 10 0" Content="{Binding VrachCount}"></Label>
                    </StackPanel>
                    <StackPanel Margin="50 0 0 0" Orientation="Horizontal">
                        <Label FontSize="10">Кол-во пациентов:</Label>
                        <Label Padding="10 3 10 0" Content="{Binding PacientCount}"></Label>
                    </StackPanel>
                </StackPanel>
            </StatusBar>
        </StackPanel>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="1.9*"/>
                <RowDefinition Height="0.7*"/>
                <RowDefinition Height="0.9*"/>
            </Grid.RowDefinitions>
            <StackPanel Grid.Row="0" Grid.Column="0">
                <StackPanel Orientation="Horizontal">
                    <Label Width="80">Фамилия:</Label>
                    <TextBox x:Name="f" Width="100" Height="20" Margin="5 2 0 0"></TextBox>
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <Label Width="80">Имя:</Label>
                    <TextBox x:Name="i" Width="100" Height="20" Margin="5 2 0 0"></TextBox>
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <Label Width="80">Отчество:</Label>
                    <TextBox x:Name="o" Width="100" Height="20" Margin="5 2 0 0"></TextBox>
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <Label Width="95">Специализация</Label>
                    <ComboBox x:Name="spec" Width="85" Height="20" Margin="5 3 0 0">
                        <ComboBoxItem Name="Хирург">Хирург</ComboBoxItem>
                        <ComboBoxItem Name="Терапевт">Терапевт</ComboBoxItem>
                        <ComboBoxItem Name="Стоматолог">Стоматолог</ComboBoxItem>
                        <ComboBoxItem Name="Педиатр">Педиатр</ComboBoxItem>
                        <ComboBoxItem Name="Дерматолог">Дерматолог</ComboBoxItem>
                    </ComboBox>
                </StackPanel>
                <StackPanel Orientation="Vertical">
                    <Label>Пароль:</Label>
                    <TextBox x:Name="par" Width="auto" Height="20" Margin="10 0 10 0"></TextBox>
                </StackPanel>
                <StackPanel Orientation="Vertical">
                    <Label>Подтвердение пароля:</Label>
                    <TextBox x:Name="ppar" Width="auto" Height="20" Margin="10 0 10 0"></TextBox>
                </StackPanel>
                <Button Height="20" Margin="40 5 40 0" Click="Button_Click">Регистрация</Button>
            </StackPanel>
            <StackPanel Grid.Row="1" Grid.Column="0" Margin="0 15 0 0">
                <StackPanel Orientation="Horizontal">
                    <Label Width="80">ID врача</Label>
                    <ComboBox x:Name="id_vrach" Width="100" Height="20" Margin="5 0 5 0"
                              ItemsSource="{Binding VrachFiles}"
                              SelectedItem="{Binding SelectedVrachFile, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                    </ComboBox>
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <Label Width="80">Пароль</Label>
                    <TextBox x:Name="Pas_vhod" Width="100" Height="20" Margin="5 0 5 0"
                             Text="{Binding VrachPassword, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"></TextBox>
                </StackPanel>
            </StackPanel>
            <StackPanel Grid.Row="2" Grid.Column="0">
                <Label>Фио:</Label>
                <Label Height="25" FontSize="10" Content="{Binding FioText}"></Label>
                <Label Margin="0 5 0 0">Специализация:</Label>
                <Label Height="25" FontSize="10" Content="{Binding SpecText}"></Label>
            </StackPanel>
        </Grid>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.5*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="0.1*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <StackPanel Grid.Row="0" Grid.Column="1">
                <StackPanel Orientation="Horizontal">
                    <Label Width="80">ID Пациента:</Label>
                    <ComboBox x:Name="id_pacient" Width="150" Margin="0 4 5 2"
                              ItemsSource="{Binding PacientFiles}"
                              SelectedItem="{Binding SelectedPacientFile, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"></ComboBox>
                </StackPanel>
            </StackPanel>
            <StackPanel Grid.Row="2" Grid.Column="0">
                <Label>Фио:</Label>
                <Label Height="25" FontSize="10" Margin="5 0 5 0" 
                       Content="{Binding CurrentPacient.LastName}"></Label>
                <Label Margin="0 5 0 0">Дата рождения:</Label>
                <Label Height="25" FontSize="10" Margin="5 0 5 0" 
                       Content="{Binding CurrentPacient.Birthday}"></Label>
                <StackPanel Orientation="Horizontal">
                    <Label Width="115">Последний прием:</Label>
                    <DatePicker x:Name="lastAppointment" Width="115" Margin="0 2 5 2" 
                                SelectedDate="{Binding CurrentPacient.LastAppointment, Mode=TwoWay}"></DatePicker>
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <Label Width="80">Диагноз:</Label>
                    <TextBox Width="150" Margin="0 4 5 2" 
                             Text="{Binding CurrentPacient.Diagnosis, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"></TextBox>
                </StackPanel>
                <StackPanel Orientation="Vertical">
                    <Label>Рекомендации:</Label>
                    <TextBox Width="auto" Margin="5 0 5 2" Padding="0 0 0 30"
                             Text="{Binding CurrentPacient.Recomendations, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"></TextBox>
                </StackPanel>
                <Button Height="20" Margin="30 5 30 0" Click="Button_Click_3">Сохранить</Button>
            </StackPanel>
        </Grid>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="1*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <StackPanel Grid.Row="0" Grid.Column="0">
                <StackPanel Orientation="Horizontal">
                    <Label Width="80">Фамилия:</Label>
                    <TextBox x:Name="f_pac" Width="100" Height="20" Margin="5 2 5 0"></TextBox>
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <Label Width="80">Имя:</Label>
                    <TextBox x:Name="i_pac" Width="100" Height="20" Margin="5 2 5 0"></TextBox>
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <Label Width="80">Отчество:</Label>
                    <TextBox x:Name="o_pac" Width="100" Height="20" Margin="5 2 5 0"></TextBox>
                </StackPanel>
                <StackPanel Orientation="Vertical">
                    <Label>Дата рождения:</Label>
                    <DatePicker x:Name="date_pac" Width="100" Margin="5 2 0 3" DisplayDateStart="2025-01-01" DisplayDateEnd="2026-01-01"></DatePicker>
                </StackPanel>
                <Button Height="20" Margin="20 5 20 0" Click="Button_Click_2">Регистрация пациента</Button>
            </StackPanel>
            <StackPanel Grid.Row="1" Grid.Column="0">
                <StackPanel Orientation="Horizontal">
                    <Label Width="80">Фамилия:</Label>
                    <TextBox Width="100" Height="20" Margin="5 2 5 0"
                             Text="{Binding CurrentPacient.LastName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"></TextBox>
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <Label Width="80">Имя:</Label>
                    <TextBox Width="100" Height="20" Margin="5 2 5 0"
                             Text="{Binding CurrentPacient.Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"></TextBox>
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <Label Width="80">Отчество:</Label>
                    <TextBox Width="100" Height="20" Margin="5 2 5 0"
                             Text="{Binding CurrentPacient.MiddleName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"></TextBox>
                </StackPanel>
                <StackPanel Orientation="Vertical">
                    <Label>Дата рождения:</Label>
                    <TextBox Width="100" Margin="5 2 0 3"
                             Text="{Binding CurrentPacient.Birthday, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"></TextBox>
                </StackPanel>
                <Button Height="20" Margin="20 5 20 0" Click="ChangePatient_Click">Изменение пациента</Button>
                <Button Height="20" Margin="20 5 20 0" Click="Reset_Click">Сбросить</Button>
            </StackPanel>
        </Grid>
    </DockPanel>
</Window>